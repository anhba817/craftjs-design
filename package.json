{
  "name": "@crafted-design/editor",
  "version": "1.3.0",
  "description": "A pluggable drag-and-drop website builder built on Craft.js — pick your design system (shadcn, MUI, Chakra…), drop the editor in, ship.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhba817/craftjs-design.git"
  },
  "bugs": {
    "url": "https://github.com/anhba817/craftjs-design/issues"
  },
  "homepage": "https://github.com/anhba817/craftjs-design#readme",
  "main": "./dist-lib/index.js",
  "types": "./dist-lib/main-app.d.ts",
  "bin": {
    "crafted-design": "./dist-lib/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist-lib/main-app.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./core": {
      "types": "./dist-lib/core.d.ts",
      "import": "./dist-lib/core.js"
    },
    "./adapters/shadcn": {
      "types": "./dist-lib/adapters/shadcn/index.d.ts",
      "import": "./dist-lib/adapters/shadcn.js"
    },
    "./adapters/mui": {
      "types": "./dist-lib/adapters/mui/index.d.ts",
      "import": "./dist-lib/adapters/mui.js"
    },
    "./adapters/html": {
      "types": "./dist-lib/adapters/html/index.d.ts",
      "import": "./dist-lib/adapters/html.js"
    },
    "./sdk": {
      "types": "./dist-lib/sdk/index.d.ts",
      "import": "./dist-lib/sdk.js"
    },
    "./headless": {
      "types": "./dist-lib/headless/index.d.ts",
      "import": "./dist-lib/headless.js"
    },
    "./renderer": {
      "types": "./dist-lib/renderer/index.d.ts",
      "import": "./dist-lib/renderer.js"
    },
    "./vite-plugin": {
      "types": "./dist-lib/vite/safelistPlugin.d.ts",
      "import": "./dist-lib/vite-plugin.js"
    },
    "./index.css": "./dist-lib/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css",
    "**/main-app.tsx",
    "**/core.tsx",
    "**/registry/components/**",
    "**/registry/fonts.ts",
    "**/adapters/shadcn/**",
    "**/adapters/mui/**",
    "**/adapters/html/**",
    "**/themes/**",
    "**/editor/inspector/built-in-panels.ts",
    "**/persistence/templates/**"
  ],
  "files": [
    "dist-lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dist": "tsc -b && vite build --config vite.config.dist.ts && npm run copy-cli-templates",
    "build:demo": "npm run gen-safelist && vite build --config vite.config.demo.ts",
    "build:gallery": "tsx scripts/build-gallery.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "gen-safelist": "tsx scripts/gen-safelist.ts",
    "predev": "npm run gen-safelist",
    "prebuild": "npm run gen-safelist",
    "prebuild:dist": "npm run gen-safelist",
    "docs": "typedoc",
    "docs:html": "typedoc --options typedoc.html.json",
    "docs:site": "tsx scripts/build-docs-site.ts",
    "docs:matrix": "tsx scripts/adapter-matrix.ts",
    "check:size": "tsx scripts/check-bundle-size.ts",
    "check:chrome": "tsx scripts/check-chrome-tokens.ts",
    "check:cli": "tsx scripts/check-cli-scaffold.ts",
    "check:example": "tsx scripts/check-example.ts",
    "copy-cli-templates": "tsx scripts/copy-cli-templates.ts",
    "check:licenses": "tsx scripts/check-licenses.ts",
    "analyze": "ANALYZE=1 vite build --config vite.config.dist.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build:dist && changeset publish",
    "prepare": "lefthook install || true",
    "prepublishOnly": "npm run build:dist && vitest run"
  },
  "peerDependencies": {
    "@craftjs/core": "^0.2.12",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/material": "^9",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@mui/material": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tanstack/react-virtual": "^3.13.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "radix-ui": "^1.4.3",
    "react-colorful": "^5.7.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@chakra-ui/react": "^3.35.0",
    "@changesets/cli": "^2.31.0",
    "@craftjs/core": "^0.2.12",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mui/material": "^9.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "marked": "^14.1.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "craftjs",
    "drag-and-drop",
    "website-builder",
    "page-builder",
    "design-system",
    "shadcn",
    "mui",
    "chakra",
    "react",
    "editor",
    "wysiwyg",
    "low-code"
  ]
}
