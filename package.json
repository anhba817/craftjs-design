{
  "name": "@crafted-design/editor",
  "version": "0.1.0",
  "description": "A pluggable drag-and-drop website builder built on Craft.js — pick your design system (shadcn, MUI, Chakra…), drop the editor in, ship.",
  "license": "MIT",
  "type": "module",
  "main": "./dist-lib/index.js",
  "types": "./dist-lib/main-app.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/main-app.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./sdk": {
      "types": "./dist-lib/sdk/index.d.ts",
      "import": "./dist-lib/sdk.js"
    },
    "./index.css": "./dist-lib/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist-lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dist": "tsc -b && vite build --config vite.config.dist.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "gen-safelist": "tsx scripts/gen-safelist.ts",
    "predev": "npm run gen-safelist",
    "prebuild": "npm run gen-safelist",
    "prebuild:dist": "npm run gen-safelist",
    "docs": "typedoc",
    "prepublishOnly": "npm run build:dist && vitest run"
  },
  "peerDependencies": {
    "@craftjs/core": "^0.2.12",
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@mui/material": "^9.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "radix-ui": "^1.4.3",
    "react-colorful": "^5.7.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@craftjs/core": "^0.2.12",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "craftjs",
    "drag-and-drop",
    "website-builder",
    "page-builder",
    "design-system",
    "shadcn",
    "mui",
    "chakra",
    "react",
    "editor",
    "wysiwyg",
    "low-code"
  ]
}
