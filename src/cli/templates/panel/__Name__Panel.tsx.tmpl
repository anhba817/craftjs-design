// __title__ panel — generated by `crafted-design scaffold panel`.
//
// An inspector panel is a section in the right-hand Inspector. It receives the
// primary selected node id (plus the full selection and active style slot) and
// edits that node. This skeleton edits the node's Tailwind class string via
// `useNodeClasses`; swap the textarea for your own controls.
import { registerPanel, useNodeClasses } from '@crafted-design/editor/sdk'

function __Name__Panel({ nodeId }: { nodeId: string }) {
  const { classString, writeClasses } = useNodeClasses(nodeId)
  return (
    <label style={{ display: 'block', fontSize: 12 }}>
      <span>__title__</span>
      <textarea
        value={classString}
        onChange={(e) => writeClasses(e.target.value)}
        rows={2}
        style={{ width: '100%' }}
      />
    </label>
  )
}

registerPanel({
  id: '__id__',
  displayName: '__title__',
  // Render order. Built-ins use 10–70; 100 places this after all of them.
  order: 100,
  // Consulted when a canonical does NOT declare an explicit applicablePanels
  // whitelist. Return true to show this panel for the given canonical. (If a
  // canonical DOES whitelist panels, add '__id__' to its applicablePanels.)
  applicableTo: () => true,
  component: __Name__Panel,
})
